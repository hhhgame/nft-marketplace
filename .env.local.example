# WalletConnect Project ID
# 从 https://cloud.walletconnect.com/ 获取
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id

# RPC 节点配置
# 主网 - Ethereum Mainnet
NEXT_PUBLIC_ETHEREUM_MAINNET_RPC=https://eth.llamarpc.com

# 测试网 - Sepolia
NEXT_PUBLIC_SEPOLIA_RPC=https://eth-sepolia.g.alchemy.com/v2/your-alchemy-api-key

# 测试网 - Goerli (已弃用，建议使用 Sepolia)
# NEXT_PUBLIC_GOERLI_RPC=https://eth-goerli.g.alchemy.com/v2/your-alchemy-api-key

# Polygon 主网
NEXT_PUBLIC_POLYGON_MAINNET_RPC=https://polygon.llamarpc.com

# Polygon 测试网 (Mumbai)
NEXT_PUBLIC_POLYGON_MUMBAI_RPC=https://polygon-mumbai.g.alchemy.com/v2/your-alchemy-api-key

# Base 主网
NEXT_PUBLIC_BASE_MAINNET_RPC=https://mainnet.base.org

# Base 测试网 (Sepolia)
NEXT_PUBLIC_BASE_SEPOLIA_RPC=https://sepolia.base.org

# Arbitrum 主网
NEXT_PUBLIC_ARBITRUM_MAINNET_RPC=https://arb1.arbitrum.io/rpc

# 合约地址 (部署后填写)
# NEXT_PUBLIC_NFT_CONTRACT_ADDRESS=0x...
# NEXT_PUBLIC_MARKETPLACE_CONTRACT_ADDRESS=0x...

# 应用名称
NEXT_PUBLIC_APP_NAME=NFT Marketplace

# 应用描述
NEXT_PUBLIC_APP_DESCRIPTION=A decentralized NFT marketplace

# NFTScan NFT API 配置
# 从 https://www.nftscan.com/ 获取免费 API Key
# 注册后在 Dashboard 中获取 API KEY
# 免费额度：1M CU，永不过期
NEXT_PUBLIC_NFTSCAN_API_KEY=your-nftscan-api-key
NEXT_PUBLIC_NFTSCAN_BASE_URL=https://restapi.nftscan.com

# 链配置 (用于 NFTScan API)
# NFTScan 支持 22 条区块链：
# - ethereum: Ethereum 主网
# - bnb: BNB Chain (原 BSC)
# - polygon: Polygon
# - arbitrum: Arbitrum One
# - optimism: Optimism
# - base: Base
# - zksync: zkSync Era
# - linea: Linea
# - scroll: Scroll
# - viction: Viction
# - fantom: Fantom
# - mantle: Mantle
# - moonbeam: Moonbeam
# - platon: PlatON
# - cronos: Cronos
# - gnosis: Gnosis
# - aptos: Aptos
# - solana: Solana
# - bitcoin: Bitcoin
# - ton: TON
# - starknet: StarkNet
# - avalanche: Avalanche
NEXT_PUBLIC_DEFAULT_CHAIN=ethereum
